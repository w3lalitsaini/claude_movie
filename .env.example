# ─── DATABASE ───────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/?appName=Cluster

# ─── NEXT AUTH ──────────────────────────────────────────────
NEXTAUTH_SECRET=your-super-secret-key-min-32-chars
NEXTAUTH_URL=https://yourdomain.com

# ─── CLOUDINARY (image uploads) ─────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── GOOGLE ANALYTICS ───────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ─── GOOGLE ADSENSE ─────────────────────────────────────────
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_AD_SLOT_AUTO=0000000000
NEXT_PUBLIC_AD_SLOT_IN_ARTICLE=0000000000
NEXT_PUBLIC_AD_SLOT_POSTER=0000000000

# ─── SITE CONFIG ────────────────────────────────────────────
SITE_NAME=AtoZ Movies
SITE_URL=https://yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com
